# Database
DATABASE_URL=postgresql://avatar:avatar@localhost:5432/avatar

# LLM Provider: "gemini" (default, free tier) or "anthropic"
LLM_PROVIDER=gemini

# Anthropic (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-haiku-4-5-20241022

# Gemini (required when LLM_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Server
PORT=3000
